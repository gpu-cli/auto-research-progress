---
import SiteLayout from '../layouts/SiteLayout.astro';
import JournalRow from '../components/JournalRow.astro';
import {
  getJournal,
  JOURNAL_PAGE_SIZE,
  titleOf,
  summaryOf,
  imageOf,
  dateOf,
  toJournalCard,
} from '../lib/journal';

const { entries, featured, remaining } = await getJournal();
const cards = remaining.map(toJournalCard);
const initialCards = cards.slice(0, JOURNAL_PAGE_SIZE);
const nextCursor = cards.length > JOURNAL_PAGE_SIZE ? '2' : '';
---
<SiteLayout>
  <section class="journal-intro">
    <div class="eyebrow"><span class="live-pulse"></span> Autonomous research log</div>
    <h1>Progress, with<br /><em>the evidence attached.</em></h1>
    <div class="intro-meta">
      <p>Practical AI research for Forge: papers become experiments, experiments become artifacts, and only verified results become engineering decisions.</p>
      <dl><div><dt>Archive</dt><dd>{entries.length} entries</dd></div><div><dt>Focus</dt><dd>Diffusion · LLMs · systems</dd></div></dl>
    </div>
  </section>

  {featured && (
    <section class="lead-story" aria-labelledby="lead-title">
      <a class="lead-copy" href={`/progress/${featured.id}/`}>
        <div class="story-meta"><span>{featured.data.kind}</span><span>{featured.data.status}</span>{dateOf(featured) && <time>{dateOf(featured)?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}</time>}</div>
        <h2 id="lead-title">{titleOf(featured)}</h2>
        <p>{summaryOf(featured)}</p>
        <span class="read-link">Read the evidence <span aria-hidden="true">↗</span></span>
      </a>
      {imageOf(featured) ? <a class="lead-visual" href={`/progress/${featured.id}/`}><img src={imageOf(featured)} alt="" loading="eager" /></a> : <div class="lead-visual type-visual"><span>R / {String(entries.length).padStart(3, '0')}</span></div>}
    </section>
  )}

  <section class="archive" aria-labelledby="archive-heading">
    <header class="archive-head"><h2 id="archive-heading">Research journal</h2><p>Newest first · <a href="/archive/">static index</a></p></header>
    <div class="filter-bar" role="group" aria-label="Filter journal">
      {['all', 'experiment', 'report', 'paper', 'note'].map((kind) => <button type="button" data-filter={kind} class:list={{ active: kind === 'all' }}>{kind}</button>)}
    </div>
    <div
      class="journal-list"
      data-next-cursor={nextCursor}
      data-total={cards.length}
      aria-busy="false"
      aria-live="polite"
    >
      {initialCards.map((entry) => <JournalRow entry={entry} />)}
    </div>
    <p class="empty-filter" hidden>No entries in this lane yet.</p>
    <div class="journal-sentinel" data-journal-sentinel>
      <span class="journal-load-status" aria-live="polite">{nextCursor ? `${initialCards.length} of ${cards.length} entries loaded` : `All ${cards.length} entries loaded`}</span>
      <button class="journal-load-button" type="button" hidden={!nextCursor}>Load more</button>
    </div>
    <noscript><p class="journal-noscript">Infinite loading requires JavaScript. <a href="/archive/">Open the complete static archive</a>.</p></noscript>
  </section>

  <template id="journal-row-template">
    <article class="journal-row" data-kind="">
      <a data-field="url">
        <div class="row-index" data-field="index"></div>
        <div class="row-copy">
          <div class="story-meta"><span data-field="kind"></span><span data-field="status"></span></div>
          <h3 data-field="title"></h3>
          <p data-field="summary"></p>
        </div>
        <div class="row-end">
          <span data-field="image-slot"></span>
          <time data-field="date"></time>
          <span aria-hidden="true">↗</span>
        </div>
      </a>
    </article>
  </template>
  <script is:inline src="/journal-filter.js" defer></script>
</SiteLayout>
