---
import type { CollectionEntry } from 'astro:content';
import SiteLayout from './SiteLayout.astro';
import MediaGallery from '../components/MediaGallery.astro';

const { entry } = Astro.props as { entry: CollectionEntry<'progress'> };
const title = entry.data.title ?? (entry.body ?? '').match(/^#\s+(.+)$/m)?.[1] ?? entry.id;
const description = entry.data.description ?? 'Research progress report and supporting evidence.';
const date = entry.data.date ?? entry.data.updated;
---
<SiteLayout title={title} description={description}>
  <article class="entry-shell">
    <header class="entry-header">
      <a class="back-link" href="/">← Journal</a>
      <div class="entry-kicker">
        <span class:list={['status-dot', entry.data.status]}></span>
        <span>{entry.data.kind}</span>
        <span>{entry.data.status}</span>
        {date && <time datetime={date.toISOString()}>{date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>}
      </div>
      <h1>{title}</h1>
      {entry.data.description && <p class="entry-deck">{entry.data.description}</p>}
      {entry.data.tags.length > 0 && <div class="tag-row">{entry.data.tags.map((tag) => <span>{tag}</span>)}</div>}
    </header>
    <MediaGallery items={entry.data.media} />
    <div class="article-rule" aria-hidden="true"><span></span></div>
    <div class="article-layout">
      <aside class="article-rail" aria-label="Entry context">
        <span>Research note</span>
        <strong>{entry.data.kind}</strong>
        <small>Permanent archive</small>
      </aside>
      <div class="typeset typeset-report article-body">
        <slot />
      </div>
    </div>
  </article>
</SiteLayout>
